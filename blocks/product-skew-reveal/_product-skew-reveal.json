{
  "definitions": [
    {
      "title": "Product Skew Reveal",
      "id": "product-skew-reveal",
      "model": "product-skew-reveal",
      "filter": "product-skew-reveal",
      "plugins": {
        "da": {
          "name": "product-skew-reveal",
          "rows": 1,
          "columns": 3
        }
      }
    },
    {
      "title": "Product Skew Reveal Header",
      "id": "product-skew-reveal-header",
      "model": "product-skew-reveal-header",
      "plugins": {
        "da": {
          "name": "product-skew-reveal-header",
          "rows": 1,
          "columns": 3,
          "fields": [
            { "name": "title", "selector": "div:nth-child(1)" },
            { "name": "subtitleLines", "selector": "div:nth-child(2)" },
            { "name": "alignment", "selector": "div:nth-child(3)" }
          ]
        }
      }
    },
    {
      "title": "Product Skew Reveal Tile",
      "id": "product-skew-reveal-tile",
      "model": "product-skew-reveal-tile",
      "plugins": {
        "da": {
          "name": "product-skew-reveal-tile",
          "rows": 1,
          "columns": 10,
          "fields": [
            { "name": "variant", "selector": "div:nth-child(1)" },
            { "name": "span", "selector": "div:nth-child(2)" },
            { "name": "label", "selector": "div:nth-child(3)" },
            { "name": "name", "selector": "div:nth-child(4)" },
            { "name": "link", "selector": "div:nth-child(5)" },
            { "name": "backgroundStyle", "selector": "div:nth-child(6)" },
            { "name": "image", "selector": "div:nth-child(7)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(8)" },
            { "name": "videoUrl", "selector": "div:nth-child(9)" },
            { "name": "fallbackShape", "selector": "div:nth-child(10)" }
          ]
        }
      }
    }
  ],
